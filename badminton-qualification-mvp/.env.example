# Local development keeps using SQLite by default.
DATABASE_URL="file:./dev.db"
APP_MODE="demo"

# Only required for APP_MODE=production.
SUPER_ADMIN_EMAIL="owner@example.com"
SUPER_ADMIN_PASSWORD="change-this-password"
SUPER_ADMIN_NAME="平台管理员"

# Existing Render service redeploy:
# Build Command: npm ci --include=dev && npm run render:build
# Pre-Deploy Command: npm run render:predeploy
# Start Command: npm run start
#
# Demo Render deployment:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# APP_MODE="demo"
# PERSIST_UPLOAD_FILES="false"
# NODE_ENV="production"
# UPLOAD_DIR="./storage/uploads"
#
# Formal Render deployment:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# APP_MODE="production"
# SUPER_ADMIN_EMAIL="owner@example.com"
# SUPER_ADMIN_PASSWORD="change-this-password"
# SUPER_ADMIN_NAME="平台管理员"
# APP_BASE_URL="https://your-app.onrender.com"
# PERSIST_UPLOAD_FILES="false"
# NODE_ENV="production"
# UPLOAD_DIR="./storage/uploads"

# Local development keeps using SQLite by default.
DATABASE_URL="file:./dev.db"

# Existing Render service redeploy:
# Build Command: npm ci --include=dev && npm run render:build
# Pre-Deploy Command: npm run render:predeploy
# Start Command: npm run start
#
# Render + PostgreSQL deployment:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# PERSIST_UPLOAD_FILES="false"
# NODE_ENV="production"
# UPLOAD_DIR="./storage/uploads"

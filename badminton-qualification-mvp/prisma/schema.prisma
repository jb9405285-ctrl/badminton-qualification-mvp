generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  name                 String
  email                String                 @unique
  passwordHash         String?
  role                 String                 @default("ORGANIZER")
  status               String                 @default("ACTIVE")
  organizationId       String?
  lastLoginAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  organization         Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  events               Event[]
  sessions             Session[]
  uploadBatches        UploadBatch[]
  deletedUploadBatches UploadBatch[]          @relation("UploadBatchDeletedBy")
  archivedUploadBatches UploadBatch[]         @relation("UploadBatchArchivedBy")
  batchAuditLogs       BatchAuditLog[]        @relation("BatchAuditLogActor")
  reviewedApplications OrganizerApplication[] @relation("OrganizerApplicationReviewedBy")
  approvedApplications OrganizerApplication[] @relation("OrganizerApplicationApprovedUser")
  passwordSetupTokens  PasswordSetupToken[]

  @@index([organizationId, createdAt])
  @@index([role, createdAt])
  @@index([status, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id           String                 @id @default(cuid())
  name         String
  slug         String                 @unique
  contactName  String?
  contactEmail String?
  contactPhone String?
  status       String                 @default("ACTIVE")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  users        User[]
  events       Event[]
  applications OrganizerApplication[]
}

model OrganizerApplication {
  id               String        @id @default(cuid())
  organizationName String
  contactName      String
  contactEmail     String
  contactPhone     String?
  note             String?
  status           String        @default("PENDING")
  reviewedAt       DateTime?
  reviewedById     String?
  reviewNote       String?
  organizationId   String?
  approvedUserId   String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reviewedBy       User?         @relation("OrganizerApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  approvedUser     User?         @relation("OrganizerApplicationApprovedUser", fields: [approvedUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([contactEmail, createdAt])
}

model PasswordSetupToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([usedAt])
}

model Event {
  id                  String               @id @default(cuid())
  organizationId      String?
  name                String
  organizerName       String
  eventDate           DateTime
  notes               String?
  status              String               @default("DRAFT")
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy           User                 @relation(fields: [createdById], references: [id], onDelete: Restrict)
  batches             UploadBatch[]
  verificationRecords VerificationRecord[]

  @@index([organizationId, createdAt])
  @@index([eventDate])
  @@index([createdAt])
}

model Athlete {
  id                  String               @id @default(cuid())
  externalKey         String               @unique
  name                String
  gender              String?
  region              String?
  organization        String?
  level               String
  certificateNo       String?
  sport               String               @default("羽毛球")
  certifiedAt         DateTime?
  sourceName          String
  sourceUrl           String?
  sourceType          String               @default("mock")
  dataStatus          String               @default("演示数据")
  riskCategory        String               @default("CLEAR")
  providerKey         String               @default("mock")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  verificationRecords VerificationRecord[]

  @@index([name])
  @@index([level])
}

model UploadBatch {
  id                 String               @id @default(cuid())
  eventId            String
  uploadedById       String
  originalFileName   String
  storedFilePath     String?
  fileType           String
  status             String               @default("PENDING")
  detectedNameColumn String?
  isDeleted          Boolean              @default(false)
  deletedAt          DateTime?
  deletedById        String?
  archivedAt         DateTime?
  archivedById       String?
  totalRows          Int                  @default(0)
  processedRows      Int                  @default(0)
  matchedRows        Int                  @default(0)
  riskRows           Int                  @default(0)
  unresolvedRows     Int                  @default(0)
  columnsJson        String?
  previewRowsJson    String?
  rawRowsJson        String?
  summaryJson        String?
  errorMessage       String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy         User                 @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  deletedBy          User?                @relation("UploadBatchDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  archivedBy         User?                @relation("UploadBatchArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  verificationRecords VerificationRecord[]
  auditLogs          BatchAuditLog[]

  @@index([eventId, createdAt])
  @@index([isDeleted, createdAt])
  @@index([archivedAt])
  @@index([deletedAt])
}

model VerificationRecord {
  id                  String             @id @default(cuid())
  eventId             String
  batchId             String?
  athleteId           String?
  athleteNameInput    String
  matchedAthleteName  String?
  matchedLevel        String?
  matchedGender       String?
  matchedRegion       String?
  matchedOrganization String?
  matchedSourceName   String?
  status              String
  riskCategory        String
  isRisk              Boolean            @default(false)
  remark              String?
  rowIndex            Int?
  rowDataJson         String?
  queryTime           DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  event               Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  batch               UploadBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  athlete             Athlete?           @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([batchId])
  @@index([status])
  @@index([athleteNameInput])
}

model BatchAuditLog {
  id        String   @id @default(cuid())
  batchId   String
  actorId   String?
  action    String
  detailJson String?
  createdAt DateTime @default(now())
  batch     UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  actor     User?       @relation("BatchAuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([batchId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
